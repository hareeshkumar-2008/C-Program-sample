// FINDING LARGEST NUMBERS AMONG FOUR NUMBERS
----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
* PROGRAM CODE :
-----------------------------
#include <stdio.h>

int main ()
{
    int a,b,c,d;

    printf("Enter the first numbers :");
    scanf("%d",&a);
    printf("Enter the second numbers :");
    scanf("%d",&b);
    printf("Enter the third numbers :");
    scanf("%d",&c);
    printf("Enter the four numbers :");
    scanf("%d",&d);
     
    if (a >= b && a >= c && a >= d)
        printf("%d is the largest number ",a);
    else if (b >= c)
        printf("%d is the largest number ",b);
    else if (c >= d)
        printf("%d is the largest number ",c);
    else
        printf ("%d is the largest number ",d);
    return 1;
}
------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
* OUTPUT :
Enter the first numbers :150
Enter the second numbers :165
Enter the third numbers :350
Enter the four numbers :250
