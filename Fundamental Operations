// FINDING THE GREATEST NUMBER USING C PROGRAMMING
----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
* PROGRAM CODE :
---------------------
#include <stdio.h>

int main ()
{
    int a,b,c;

    printf("Enter the first numbers :");
    scanf("%d",&a);
    printf("Enter the second numbers :");
    scanf("%d",&b);
    printf("Enter the third numbers :");
    scanf("%d",&c);
     
     if (a >= b && a <= c)
        printf("%d is the largest number ",a);
    else if (b >= c)
        printf("%d is the largest number ",b);
    else
        printf("%d is the largest number ",c);
    return 1;
}
-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
* OUTPUT :
-----------------
Enter the first numbers :25
Enter the second numbers :35
Enter the third numbers :40
40 is the largest number

