//program to add two numbers 

#include <stdio.h>
void main()
{
  
   int a,b,sum;
   
   printf("Enter two numbers:");
   scanf("%d%d",&a,&b);
   
   sum=a+b;
   
   printf("sum=%d",sum);
   
}

output
    Enter two numbers 2 4
    sum=6
