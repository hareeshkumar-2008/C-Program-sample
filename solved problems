square and cube of a given number

#include <stdio.h>

void main()
{
    int a,sqr,cube;
    
    printf("Given number");
    scanf("%d",&a);
    
    sqr=a*a;
    cube=a*a*a;
    
    printf("%d*%d=%d %d*%d*%d=%d",a,a,sqr,a,a,a,cube);
    
}

