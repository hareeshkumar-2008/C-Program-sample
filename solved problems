multiple and divide two numbers in the form of (a*b=ans a/b=ans)

#include <stdio.h>

void main()
{
    int a,b,product,diff;
    
    printf("Enter two numbers");
    scanf("%d%d",&a,&b);
    
    product=a*b;
    diff=a/b;
    
    printf("%d*%d=%d %d/%d=%d",a,b,product,a,b,diff);
    
}
