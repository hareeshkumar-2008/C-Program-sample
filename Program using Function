#include <stdio.h>
int large(int a,int b,int c){
    if(a>=b&&a>=c)
   return a;
    else if(b>=a&&b>=c)
    return b;
    else
    return c;
}
void main() {
    int a,b,c;
    printf("Enter any three numbers:");
    scanf("%d%d%d",&a,&b,&c);
    
    printf("The largest of three numbers is:%d",large(a,b,c));
    
}
